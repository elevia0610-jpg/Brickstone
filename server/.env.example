PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/brickstone

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Seed script admin user
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Contact form email via MailerSend
MAILERSEND_API_KEY=
FROM_EMAIL=
ADMIN_EMAIL=

# Cloudinary (optional: enables admin image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

